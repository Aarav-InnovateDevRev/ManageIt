<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ManageIt - AI Business Assistant</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: linear-gradient(to bottom, #fdf6e3, #f5e8c7); }
        #chat-container { max-height: 60vh; overflow-y: auto; margin-bottom: 1rem; }
        .message { margin: 0.5rem 0; padding: 0.75rem; border-radius: 12px; }
        .user { background: #8d5524; color: white; margin-left: 20%; }
        .ai { background: #fffaf0; border: 1px solid #d7b99f; margin-right: 20%; }
    </style>
</head>
<body class="container py-5">
    <h2 class="text-center mb-4">AI Business Assistant</h2>
    <div id="chat-container" class="card p-3">
        <div class="message ai">Hello! I'm your AI helper for your printing business. Ask me anything!</div>
    </div>

    <div class="input-group">
        <input type="text" id="message" class="form-control" placeholder="Type your question...">
        <button class="btn btn-primary" onclick="sendMessage()">Send</button>
    </div>

    <script>
        async function sendMessage() {
            const input = document.getElementById("message");
            const msg = input.value.trim();
            if (!msg) return;

            // Show user message
            const chat = document.getElementById("chat-container");
            chat.innerHTML += `<div class="message user">${msg}</div>`;
            input.value = "";

            // Scroll to bottom
            chat.scrollTop = chat.scrollHeight;

            // Send to /chat API
            try {
                const res = await fetch("/chat", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ message: msg })
                });
                const data = await res.json();

                if (data.reply) {
                    chat.innerHTML += `<div class="message ai">${data.reply}</div>`;
                } else {
                    chat.innerHTML += `<div class="message ai text-danger">Error: ${data.error}</div>`;
                }
            } catch (err) {
                chat.innerHTML += `<div class="message ai text-danger">Failed to connect to AI</div>`;
            }

            chat.scrollTop = chat.scrollHeight;
        }

        // Send message on Enter key
        document.getElementById("message").addEventListener("keypress", function(e) {
            if (e.key === "Enter") sendMessage();
        });
    </script>
</body>
</html>
